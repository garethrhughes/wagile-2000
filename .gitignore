# Dependencies
node_modules/
.pnp
.pnp.js

# Build outputs
dist/
build/
.next/
out/

# Environment files
.env
.env.local
.env.*.local

# Logs
*.log
npm-debug.log*

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp

# Test coverage
coverage/

# TypeScript incremental
*.tsbuildinfo

# Live board/roadmap YAML config files (contain deployment-specific values).
# The *.example.yaml annotated templates ARE tracked in git.
backend/config/boards.yaml
backend/config/roadmap.yaml

# Terraform — real tfvars files contain domain names and may contain secrets.
# Only terraform.tfvars.example (template) is committed.
infra/terraform/**/*.tfvars
# Terraform working directories (created by terraform init)
infra/terraform/**/.terraform/
infra/terraform/**/.terraform.lock.hcl

# Lambda build artefacts — produced by `make lambda-build`, uploaded to S3 by Terraform.
# Never commit binary zips; they inflate repo size and are always reproducible from source.
backend/snapshot-worker.zip

