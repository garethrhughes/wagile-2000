{
  "compilerOptions": {
    "module": "commonjs",
    "moduleResolution": "node",
    "target": "ES2020",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "typeRoots": ["../backend/node_modules/@types"],
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "pg": ["../backend/node_modules/pg/lib/index.d.ts"]
    }
  },
  "include": ["*.ts"]
}
