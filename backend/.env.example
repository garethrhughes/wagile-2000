# Jira
JIRA_BASE_URL=https://your-org.atlassian.net
JIRA_USER_EMAIL=your@email.com
JIRA_API_TOKEN=your_api_token_here
# JIRA_BOARD_IDS is no longer used. Boards are managed via the Settings UI.
# See docs/proposals/0016-ui-driven-board-management.md for migration steps.
# JIRA_BOARD_IDS=ACC,BPT,SPS,OCS,DATA,PLAT

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=fragile

# App
FRONTEND_URL=http://localhost:3000
PORT=3001

# Timezone — must be a valid IANA timezone string (e.g. America/New_York, Europe/London).
# All quarter/week boundary calculations use this timezone. Defaults to UTC.
TIMEZONE=Australia/Sydney

# Board and Roadmap configuration via YAML (optional, replaces manual Settings UI setup).
# See config/boards.example.yaml and config/roadmap.example.yaml for the full field
# reference and annotated examples. Copy each example file, remove the .example suffix,
# and edit the boards/roadmaps lists to match your deployment. If these files are absent,
# the application starts normally and configuration is managed entirely through the
# Settings UI (no changes required for existing deployments).
#
# Override the default file paths by setting these env vars (absolute or relative to CWD):
# BOARD_CONFIG_FILE=/path/to/boards.yaml
# ROADMAP_CONFIG_FILE=/path/to/roadmap.yaml
#
# Default paths (resolved relative to process.cwd(), i.e. the backend/ directory):
#   config/boards.yaml
#   config/roadmap.yaml

